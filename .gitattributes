# Normalize line endings for cross-platform clones
* text=auto eol=lf

# Swift sources
*.swift text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.xcassets/ binary

# Git LFS — model files (if ever added to the repo)
*.gguf filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text
